# Database Connection URL (PostgreSQL)
DATABASE_URL="postgresql://postgres:postgres_password@db:5432/teleflow_db?schema=public"

# AES-256 Encryption Key for Telegram Bot Token (Must be 32 characters or hashed to 32 bytes)
ENCRYPTION_KEY="teleflow-ultra-secure-secret-encryption-key-32b"

# Nuxt Listening Port
PORT=3000
